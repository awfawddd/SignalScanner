<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E17"
    android:padding="16dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📶 Wi-Fi"
        android:textColor="#00E5FF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:fontFamily="monospace"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SIGNAL SCANNER"
        android:textColor="#444444"
        android:textSize="10sp"
        android:gravity="center"
        android:letterSpacing="0.3"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <!-- Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/tab_background"
        android:padding="4dp"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnWifi"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📶\nWi-Fi"
            android:textSize="10sp"
            android:textColor="#00E5FF"
            android:background="@drawable/tab_selector"
            android:fontFamily="monospace"
            android:textAllCaps="false"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/btnBluetooth"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🔵\nBT"
            android:textSize="10sp"
            android:textColor="#448AFF"
            android:background="@drawable/tab_selector"
            android:fontFamily="monospace"
            android:textAllCaps="false"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/btnCellular"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📱\nCell"
            android:textSize="10sp"
            android:textColor="#76FF03"
            android:background="@drawable/tab_selector"
            android:fontFamily="monospace"
            android:textAllCaps="false"
            android:layout_margin="2dp" />

        <Button
            android:id="@+id/btnGps"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🛰️\nGPS"
            android:textSize="10sp"
            android:textColor="#FFAB00"
            android:background="@drawable/tab_selector"
            android:fontFamily="monospace"
            android:textAllCaps="false"
            android:layout_margin="2dp" />
    </LinearLayout>

    <!-- Connection Panel -->
    <LinearLayout
        android:id="@+id/connectionPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/item_background"
        android:padding="14dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvConnDevice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dispositivo"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvConnStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟡 Connessione..."
                    android:textColor="#FFAB00"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Disconnetti"
                android:textColor="#FF1744"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textAllCaps="false"
                android:background="@drawable/scan_button_bg"
                android:paddingHorizontal="12dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvConnServices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#888888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="10dp" />
    </LinearLayout>

    <!-- Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Premi Scansiona"
            android:textColor="#666666"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 rilevati"
            android:textColor="#00E5FF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="@drawable/count_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="2dp" />
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        android:indeterminateTint="#00E5FF" />

    <!-- Results List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Scan Button -->
    <Button
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="▶  AVVIA SCANSIONE"
        android:textColor="#00E5FF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:background="@drawable/scan_button_bg"
        android:textAllCaps="false" />

</LinearLayout>
